# Umgebungsvariablen — Panda-Bande Kinderevents
# Kopiere diese Datei nach .env.local und trage echte Werte ein.
# Zentrale Dokumentation: lib/system-config.ts

# ─── Öffentliche Website-URL ─────────────────────────────────
# Steuert Canonical URLs, Sitemap, OpenGraph, Admin-Links und PDF-Auflösung.
# Domainwechsel: Wert setzen + CMS → Domain & SEO → neu deployen. Kein Code nötig.
NEXT_PUBLIC_SITE_URL=https://ihre-domain.de

# Feste Produktions-URL für E-Mail-Bilder (Logo etc.) — nie Vercel-Preview verwenden
EMAIL_ASSET_BASE_URL=https://www.ihre-domain.de

# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── E-Mail (Resend) ────────────────────────────────────────
# API-Key von https://resend.com — Absender/Reply-To im CMS (Einstellungen → E-Mail)
RESEND_API_KEY=re_your_api_key
# Optional: Fallback für Benachrichtigungen, wenn im CMS leer
INQUIRY_NOTIFICATION_EMAIL=info@ihre-domain.de

# ─── Admin ──────────────────────────────────────────────────
ADMIN_PASSWORD=change-me-to-a-strong-password

# ─── Admin PWA Web Push (VAPID) ─────────────────────────────
# Generieren: npm run generate:vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:info@ihre-domain.de

# ─── Google (optional — vorbereitet, leer lassen bis Aktivierung) ─
# Alternativ oder zusätzlich im CMS unter Einstellungen → Domain & SEO
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GTM_ID=
GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
