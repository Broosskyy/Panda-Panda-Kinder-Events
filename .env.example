# Umgebungsvariablen — Panda-Bande Kinderevents
# Kopiere diese Datei nach .env.local und trage echte Werte ein.

# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── E-Mail (Resend) ────────────────────────────────────────
# API-Key von https://resend.com — Absender/Reply-To werden im CMS konfiguriert
# (Einstellungen → E-Mail). Ohne verifizierte Domain wird onboarding@resend.dev genutzt.
RESEND_API_KEY=re_your_api_key
# Optional: Fallback für Benachrichtigungen, wenn im CMS leer
INQUIRY_NOTIFICATION_EMAIL=info@ihre-domain.de

# ─── Admin ──────────────────────────────────────────────────
ADMIN_PASSWORD=change-me-to-a-strong-password
